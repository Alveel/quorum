package view

import (
	"fmt"
	"github.com/alveel/vacation-coverage/internal/locale"
	"github.com/alveel/vacation-coverage/internal/vacation"
)

templ VacationForm() {
	<section>
		<h3>{ locale.T(ctx, "register_leave") }</h3>
		<form
			hx-post="/vacations"
			hx-target="#form-response"
			hx-swap="innerHTML"
		>
			<div class="grid">
				<label>
					{ locale.T(ctx, "label_from") }
					<input type="date" name="start_date" required/>
				</label>
				<label>
					{ locale.T(ctx, "label_to") }
					<input type="date" name="end_date" required/>
				</label>
			</div>
			<label>
				{ locale.T(ctx, "label_note_optional") }
				<input type="text" name="note" placeholder={ locale.T(ctx, "placeholder_note") }/>
			</label>
			<button type="submit">{ locale.T(ctx, "btn_register") }</button>
		</form>
		<div id="form-response"></div>
	</section>
}

templ MyVacations(vacations []vacation.Vacation) {
	<section id="my-vacations">
		@myVacationsInner(vacations)
	</section>
}

templ MyVacationsOOB(vacations []vacation.Vacation) {
	<section id="my-vacations" hx-swap-oob="true">
		@myVacationsInner(vacations)
	</section>
}

templ myVacationsInner(vacations []vacation.Vacation) {
	<h3>{ locale.T(ctx, "my_leave") }</h3>
	if len(vacations) == 0 {
		<p><em>{ locale.T(ctx, "no_leave") }</em></p>
	} else {
		<table>
			<thead>
				<tr>
					<th>{ locale.T(ctx, "col_from") }</th>
					<th>{ locale.T(ctx, "col_to") }</th>
					<th>{ locale.T(ctx, "col_note") }</th>
					<th>{ locale.T(ctx, "col_status") }</th>
					<th></th>
				</tr>
			</thead>
			<tbody>
				for _, v := range vacations {
					<tr>
						<td>{ locale.FormatDateMedium(ctx, v.StartDate) }</td>
						<td>{ locale.FormatDateMedium(ctx, v.EndDate) }</td>
						<td>{ v.Note }</td>
						<td>{ string(v.Status) }</td>
						<td>
							<button
								hx-delete={ fmt.Sprintf("/vacations/%s", v.ID) }
								hx-target="#my-vacations"
								hx-swap="outerHTML"
								hx-confirm={ locale.T(ctx, "confirm_cancel") }
								class="outline secondary"
							>{ locale.T(ctx, "btn_cancel") }</button>
						</td>
					</tr>
				}
			</tbody>
		</table>
	}
}

templ FormError(msg string, offendingDates []string) {
	<div class="error-banner" role="alert">
		<strong>{ locale.T(ctx, "denied_prefix") }</strong> { msg }
		if len(offendingDates) > 0 {
			<ul>
				for _, d := range offendingDates {
					<li>{ d }</li>
				}
			</ul>
		}
	</div>
}

templ FormSuccess() {
	<div class="success-banner" role="alert">{ locale.T(ctx, "leave_registered") }</div>
}

templ IndexPage(d PageData) {
	@Layout("Leave Coverage", d.User, d.IsAdmin) {
		<div class="index-layout">
			@Heatmap(d.Heatmap)
			<aside>
				@VacationForm()
				@MyVacations(d.MyVacations)
			</aside>
		</div>
	}
}
